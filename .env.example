# OpenRouter configuration used by all examples.
# Free-model availability changes over time; openrouter/free selects a
# currently available free model that supports the request's capabilities.

OPENAI_API_KEY=*** server config
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openrouter/free
# Port for the local UI server (default 8787)
PORT=8787
