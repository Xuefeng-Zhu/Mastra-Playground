# OpenRouter configuration used by all examples.
# GPT-OSS 20B is the default. The UI also offers OpenRouter's free-model
# router and other free models.

OPENAI_API_KEY=*** server config
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-oss-20b:free
# Port for the local server (default 8917 — set by npm scripts)
PORT=8917
