# Gemini is the default provider. Create a key at https://aistudio.google.com/apikey.
LLM_PROVIDER=google
GOOGLE_GENERATIVE_AI_API_KEY=replace-with-a-new-gemini-key
GOOGLE_MODEL=gemini-2.5-flash-lite

# Optional OpenRouter provider configuration.
OPENAI_API_KEY=replace-with-an-openrouter-key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-oss-20b:free

# Port for the local server (default 8917 — set by npm scripts)
PORT=8917
