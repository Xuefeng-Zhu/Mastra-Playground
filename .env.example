# API key for an OpenAI-compatible model. Used by all 3 examples.
# Either OpenAI directly, OR OpenRouter (https://openrouter.ai).
#
# OpenAI:
#   OPENAI_API_KEY=sk-...
#
# OpenRouter:
#   OPENAI_API_KEY=sk-or-...
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_MODEL=openai/gpt-4o-mini
#
# Default (no env vars set): gpt-4o-mini against OpenAI.

OPENAI_API_KEY=*** server config
# Port for the local UI server (default 8787)
PORT=8787
