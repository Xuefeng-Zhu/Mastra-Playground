{
  "name": "mastra-playground",
  "version": "0.4.0",
  "description": "Small isolated repo to learn Mastra by example. Not for production. Not part of InboxPilot.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "example:01": "tsx examples/01-support-triage/index.ts",
    "example:02": "tsx examples/02-research-agent/index.ts",
    "example:03": "tsx examples/03-code-review-agent/index.ts",
    "example:04": "tsx examples/04-parallel-research/index.ts",
    "example:05": "tsx examples/05-multi-turn-chat/index.ts",
    "example:06": "tsx examples/06-hitl-approval/index.ts",
    "example:07": "tsx examples/07-streaming-chat/index.ts",
    "example:08": "tsx examples/08-critic-loop/index.ts",
    "example:09": "tsx examples/09-multi-agent-handoff/index.ts",
    "example:10": "tsx examples/10-mastra-memory/index.ts",
    "example:11": "tsx examples/11-content-pipeline/index.ts",
    "example:12": "tsx examples/12-guardrail-redaction/index.ts",
    "example:13": "tsx examples/13-plan-and-execute/index.ts",
    "ci": "npm run format:check && npm run typecheck && npm run build && npm run test:coverage && npm run docs:check",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,css,html,md,json}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,css,html,md,json}\" --ignore-path .gitignore --ignore-path .prettierignore",
    "dev": "next dev --port 8917",
    "build": "next build",
    "start": "node scripts/prepare-standalone-static.mjs && PORT=8917 node .next/standalone/server.js",
    "health": "curl -s http://localhost:8917/api/health | head -c 500",
    "smoke": "tsx scripts/smoke.ts",
    "test": "vitest run",
    "test:ui": "vitest run scripts/ui-smoke.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:check": "node scripts/check-doc-links.mjs",
    "launch:hermes": "./scripts/launch-with-hermes-key.sh"
  },
  "keywords": [
    "mastra",
    "learning",
    "playground",
    "ai",
    "llm"
  ],
  "author": "Mastra Playground contributors",
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/openai": "^3.0.73",
    "@mastra/core": "^1.43.0",
    "@mastra/memory": "^1.21.0",
    "@xyflow/react": "^12.11.1",
    "next": "^16.2.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
